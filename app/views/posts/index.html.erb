<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
  <h1 style="font-size: 2.5rem; font-weight: 800; margin: 0;">Recent Posts</h1>
  
  <%= form_with url: posts_path, method: :get, local: true, style: "display: flex; gap: 0.5rem;" do |f| %>
    <%= f.text_field :query, value: params[:query], placeholder: "Search posts...", class: "form-control", style: "width: 250px; padding: 0.5rem 0.75rem;" %>
    <%= f.submit "Search", class: "btn btn-outline" %>
  <% end %>
</div>

<% if params[:query].present? %>
  <div style="margin-bottom: 2rem; color: var(--text-muted);">
    Showing results for "<%= params[:query] %>" 
    <%= link_to "Clear", posts_path, style: "margin-left: 0.5rem; color: var(--primary-color);" %>
  </div>
<% end %>

<% if @posts.any? %>
  <% @posts.each do |post| %>
    <% cache [post, current_user&.admin?] do %>
      <div class="post-card">
        <% if post.cover_image.attached? %>
          <%= image_tag post.cover_image.variant(resize_to_fill: [800, 400, { gravity: "auto" }]), 
                        class: "blog-card-img", 
                        alt: post.title %>
        <% end %>
        <div style="padding: 1.5rem;">
          <%= link_to post.title, post, class: "post-title-link" %>
          <div class="post-meta">
            Posted by <%= post.user.name || post.user.email %> • <%= time_ago_in_words(post.created_at) %> ago
          </div>

          <% if post.tags.any? %>
            <div class="tags">
              <% post.tags.each do |tag| %>
                <%= link_to "##{tag.name}", posts_path(query: "##{tag.name}"), class: "tag" %>
              <% end %>
            </div>
          <% end %>

          <p style="color: #475569; margin-top: 1rem;">
            <%= truncate(post.body, length: 200) %>
          </p>
          <div class="actions">
            <%= link_to "Read More", post, class: "btn btn-outline" %>
            <% if user_signed_in? && current_user.admin? %>
              <%= button_to "Delete", post, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline btn-danger" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
<% else %>
  <div class="card" style="text-align: center; padding: 4rem 2rem;">
    <h2 style="color: var(--text-muted);">No posts yet.</h2>
    <p style="margin-bottom: 2rem;">Be the first one to share something!</p>
    <%= link_to "Create First Post", new_post_path, class: "btn btn-primary" %>
  </div>
<% end %>

<div style="display: flex; justify-content: center; margin-top: 3rem;">
  <%== pagy_bootstrap_nav(@pagy) %>
</div>
