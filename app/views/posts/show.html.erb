<% cache [@post, current_user&.admin?] do %>
  <article class="card">
    <% if @post.cover_image.attached? %>
      <% if @post.cover_image.variable? %>
        <%= image_tag @post.cover_image.variant(resize_to_fill: [800, 400, { gravity: "Center" }]), class: "post-cover-image-show" %>
      <% else %>
        <%= image_tag @post.cover_image, class: "post-cover-image-show" %>
      <% end %>
    <% end %>
    
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
      <h1 class="post-title"><%= @post.title %></h1>
      <% if user_signed_in? && (@post.user == current_user || current_user.admin?) %>
        <span class="tag <%= @post.published? ? 'tag-published' : 'tag-draft' %>" style="margin-top: 0.5rem;">
          <%= @post.status.capitalize %>
        </span>
      <% end %>
    </div>

    <div class="post-meta" style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
      <span>By <%= @post.user.name || @post.user.email %></span>
      <span style="color: var(--border-color);">|</span>
      <span><%= @post.created_at.strftime("%B %d, %Y") %></span>
      <span style="color: var(--border-color);">|</span>
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <i data-lucide="clock" style="width: 1rem; height: 1rem;"></i>
        <span><%= @post.reading_time %> min read</span>
      </div>
      <span style="color: var(--border-color);">|</span>
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <i data-lucide="eye" style="width: 1rem; height: 1rem;"></i>
        <span><%= number_with_delimiter(@post.views_count) %> views</span>
      </div>
    </div>

    <% if @post.tags.any? %>
      <div class="tags">
        <% @post.tags.each do |tag| %>
          <%= link_to "##{tag.name}", posts_path(query: "##{tag.name}"), class: "tag" %>
        <% end %>
      </div>
    <% end %>

    <div class="post-body trix-content" style="margin-top: 2rem;">
      <%= @post.summary %>
    </div>

    <%= render "social_share", post: @post %>

    <div class="author-bio card" style="margin-top: 3rem; background: var(--bg-color); border: 1px solid var(--border-color); display: flex; gap: 1.5rem; align-items: flex-start; padding: 1.5rem; box-shadow: none;">
      <% if @post.user.avatar_url.present? %>
        <%= image_tag @post.user.avatar_url, style: "width: 80px; height: 80px; border-radius: 50%; object-fit: cover;" %>
      <% else %>
        <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--primary-color); color: white; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700;">
          <%= (@post.user.name.presence || @post.user.email)[0].upcase %>
        </div>
      <% end %>
      
      <div style="flex: 1;">
        <h3 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.25rem;">About <%= @post.user.name.presence || @post.user.email %></h3>
        <p style="color: var(--text-muted); margin-bottom: 1rem; line-height: 1.6;">
          <%= @post.user.bio.presence || "This author hasn't shared a bio yet." %>
        </p>
        <div style="display: flex; gap: 1rem;">
          <% if @post.user.twitter_handle.present? %>
            <%= link_to "https://twitter.com/#{@post.user.twitter_handle}", target: "_blank", style: "color: var(--text-muted);" do %>
              <i data-lucide="twitter" style="width: 1.25rem; height: 1.25rem;"></i>
            <% end %>
          <% end %>
          <% if @post.user.linkedin_url.present? %>
            <%= link_to @post.user.linkedin_url, target: "_blank", style: "color: var(--text-muted);" do %>
              <i data-lucide="linkedin" style="width: 1.25rem; height: 1.25rem;"></i>
            <% end %>
          <% end %>
          <% if @post.user.github_username.present? %>
            <%= link_to "https://github.com/#{@post.user.github_username}", target: "_blank", style: "color: var(--text-muted);" do %>
              <i data-lucide="github" style="width: 1.25rem; height: 1.25rem;"></i>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <% if user_signed_in? && (@post.user == current_user || current_user.admin?) %>
      <div class="actions" style="margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
        <%= link_to "Edit Post", edit_post_path(@post), class: "btn btn-outline" %>
        <%= button_to "Delete Post", @post, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-outline btn-danger" %>
      </div>
    <% end %>
  </article>
<% end %>

<section class="card" style="margin-top: 2rem;">
  <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">Comments (<%= @post.comments.size %>)</h2>
  
  <%= turbo_stream_from @post, :comments %>
  <div id="comments">
    <% cache [@post, "comments"] do %>
      <%= render @post.comments.ordered %>
    <% end %>
  </div>

  <div style="margin-top: 2rem;">
    <% if user_signed_in? %>
      <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem;">Add a comment</h3>
      <%= form_with(model: [@post, @post.comments.build], id: "new_comment") do |f| %>
        <div class="form-group">
          <%= f.text_area :content, class: "form-control", style: "min-height: 80px;", placeholder: "Write your comment here..." %>
        </div>
        <%= f.submit "Post Comment", class: "btn btn-primary" %>
      <% end %>
    <% else %>
      <p style="color: var(--text-muted); text-align: center;">
        <%= link_to "Sign in", new_user_session_path, style: "color: var(--primary-color); font-weight: 600;" %> to leave a comment.
      </p>
    <% end %>
  </div>
</section>

<div style="margin-top: 2rem;">
  <%= link_to "← Back to Posts", posts_path, class: "btn btn-outline" %>
</div>
