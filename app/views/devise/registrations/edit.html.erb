<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2>Edit Profile</h2>
      <p>Update your account settings</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }, data: { turbo: false }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="form-group">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter your email" %>
      </div>

      <div class="form-group">
        <%= f.label :name, "Display Name", class: "form-label" %>
        <%= f.text_field :name, class: "form-control", placeholder: "e.g. John Doe" %>
      </div>

      <div class="form-group">
        <%= f.label :bio, class: "form-label" %>
        <%= f.text_area :bio, class: "form-control", style: "min-height: 100px;", placeholder: "Tell us a bit about yourself..." %>
      </div>

      <div class="form-group">
        <%= f.label :twitter_handle, "Twitter/X Handle", class: "form-label" %>
        <%= f.text_field :twitter_handle, class: "form-control", placeholder: "username (without @)" %>
      </div>

      <div class="form-group">
        <%= f.label :linkedin_url, "LinkedIn Profile URL", class: "form-label" %>
        <%= f.url_field :linkedin_url, class: "form-control", placeholder: "https://linkedin.com/in/username" %>
      </div>

      <div class="form-group">
        <%= f.label :github_username, "GitHub Username", class: "form-label" %>
        <%= f.text_field :github_username, class: "form-control", placeholder: "username" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="flash flash-notice" style="margin-bottom: 1rem; font-size: 0.875rem;">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password, class: "form-label" %>
        <small class="text-muted" style="display: block; margin-bottom: 0.25rem;">(leave blank if you don't want to change it)</small>
        <div class="password-input-wrapper">
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "New password (optional)", data: { password_visibility_target: "input" } %>
          <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" data-password-visibility-target="icon">
            <i data-lucide="eye"></i>
          </button>
        </div>
        <% if @minimum_password_length %>
          <small class="text-muted" style="display: block; margin-top: 0.25rem;"><%= @minimum_password_length %> characters minimum</small>
        <% end %>
      </div>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <div class="password-input-wrapper">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm new password", data: { password_visibility_target: "input" } %>
          <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" data-password-visibility-target="icon">
            <i data-lucide="eye"></i>
          </button>
        </div>
      </div>

      <div class="form-group" style="padding-top: 1rem; border-top: 1px solid var(--border-color);" data-controller="password-visibility">
        <%= f.label :current_password, class: "form-label" %>
        <small class="text-muted" style="display: block; margin-bottom: 0.25rem;">(needed to confirm your changes)</small>
        <div class="password-input-wrapper">
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", placeholder: "••••••••", data: { password_visibility_target: "input" } %>
          <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" data-password-visibility-target="icon">
            <i data-lucide="eye"></i>
          </button>
        </div>
      </div>

      <div class="actions">
        <%= f.submit "Update Profile", class: "btn btn-primary", style: "width: 100%;" %>
      </div>
    <% end %>

    <div class="auth-links" style="margin-top: 2rem;">
      <h3 style="font-size: 1.125rem; margin-bottom: 1rem;">Danger Zone</h3>
      <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-outline btn-danger", style: "width: 100%;" %>
      <div style="text-align: center; margin-top: 1rem;">
        <%= link_to "Back", :back, class: "auth-link" %>
      </div>
    </div>
  </div>
</div>
